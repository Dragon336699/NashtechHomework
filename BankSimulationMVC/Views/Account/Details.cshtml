@using BankSimulationMVC.ViewModels

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@model AccountDetailsVM

<h2>Account Details</h2>

<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#depositModel">Deposit</button>
<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#withdrawModal">WithDraw</button>
<button class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#transferModal">Transfer</button>

<div class="card p-3">
    <p><strong>Account Number:</strong> @Model.Account.AccountNumber</p>
    <p><strong>Balance:</strong> @Model.Account.Balance</p>
    <p><strong>Owner Name:</strong> @Model.Account.OwnerName</p>
    <p><strong>Status:</strong> @Model.Account.Status</p>
    <p><strong>Created At:</strong> @Model.Account.CreatedAt</p>
</div>

@await Html.PartialAsync("DepositModal", Model.DepositVM)
@await Html.PartialAsync("WithdrawModal", Model.WithdrawVM)
@await Html.PartialAsync("TransferModal", Model.TransferVM)

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}
else if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]}
    </div>
}