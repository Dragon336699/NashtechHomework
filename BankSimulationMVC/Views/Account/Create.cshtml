@using BankSimulationMVC.Application.Dtos.Responses
@using BankSimulationMVC.Application.Dtos.Requests

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@model AccountRequest


<div class="card">
    <div class="card-header">
        Create new account
    </div>
    <div class="card-body">
        <form asp-action="Create" asp-controller="Account">
            <div class="d-flex flex-column">
                <label asp-for="AccountNumber"></label>
                <input placeholder="Ex: 0866616508" asp-for="AccountNumber" />
                <span asp-validation-for="AccountNumber" class="text-danger"></span>
                <label asp-for="OwnerName"></label>
                <input placeholder="Ex: Long" asp-for="OwnerName" />
                <span asp-validation-for="OwnerName" class="text-danger"></span>
                <label asp-for="InitialBalance"></label>
                <input placeholder="Ex: 0" asp-for="InitialBalance" type="number" />
                <span asp-validation-for="InitialBalance" class="text-danger"></span>
            </div>
            <button class="mt-2 btn btn-primary" type="Submit">Create account</button>
        </form>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success">
        @TempData["Success"]
    </div>
}
else if (TempData["Error"] != null)
{
    <div class="alert alert-danger">
        @TempData["Error"]
    </div>
}
