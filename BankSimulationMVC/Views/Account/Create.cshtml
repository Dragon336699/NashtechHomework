@using BankSimulationMVC.ViewModels

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@model AccountDto


<div class="card">
    <div class="card-header">
        Create new account
    </div>
    <div class="card-body">
        <form asp-action="Create" asp-controller="Account">
            <div class="d-flex flex-column">
                <label asp-for="AccountNumber"></label>
                <input placeholder="Ex: 0866616508" asp-for="AccountNumber" />
                <span asp-validation-for="AccountNumber"></span>
                <label asp-for="OwnerName"></label>
                <input placeholder="Ex: Long" asp-for="OwnerName" />
                <span asp-validation-for="OwnerName"></span>
                <label asp-for="Balance"></label>
                <input placeholder="Ex: 0" asp-for="Balance" type="number" />
                <span asp-validation-for="Balance"></span>
            </div>
            <button class="pt-2" type="Submit">Create account</button>
        </form>
    </div>
</div>
<div class="modal fade" id="createModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
    </div>
</div>