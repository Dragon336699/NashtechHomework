@using BankSimulationMVC.ViewModels

@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}

@model TransferVM

<div class="modal fade" id="transferModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form asp-action="Transfer" asp-controller="Account">
            <div class="modal-content">
                <div class="modal-header">
                    <h1 class="modal-title fs-5" id="exampleModalLabel">Transfer</h1>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body d-flex flex-column">
                    <label asp-for="SourceAccountNumber"></label>
                    <input placeholder="Ex: 0866616508" asp-for="SourceAccountNumber" />
                    <span class="text-danger" asp-validation-for="SourceAccountNumber"></span>
                    <label asp-for="DestinationAccountNumber"></label>
                    <input placeholder="Ex: 0973585128" asp-for="DestinationAccountNumber" />
                    <span class="text-danger" asp-validation-for="DestinationAccountNumber"></span>
                    <label asp-for="Amount"></label>
                    <input placeholder="Ex: 10000" asp-for="Amount" />
                    <span class="text-danger" asp-validation-for="Amount"></span>
                </div>
                <div class="modal-footer">
                    <button data-bs-dismiss="modal">Close</button>
                    <button type="Submit">Transfer</button>
                </div>
            </div>
        </form>
    </div>
</div>